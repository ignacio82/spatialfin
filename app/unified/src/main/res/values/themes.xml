<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Base theme used by the unified activity window -->
    <style name="Theme.SpatialFin" parent="Theme.AppCompat.DayNight.NoActionBar" />
    <!-- Referenced by TV composable (TvTheme) -->
    <style name="Theme.SpatialFin.Tv" parent="Theme.AppCompat.DayNight.NoActionBar" />
    <!-- Referenced by Beam composable (BeamTheme) -->
    <style name="Theme.SpatialFin.Beam" parent="Theme.AppCompat.DayNight.NoActionBar" />
    <!-- FCast inbound player. Must extend an AppCompat parent so media3's
         PlayerView / DefaultTimeBar can resolve their ?attr/... style refs.
         A plain @android:style/Theme.Black.NoTitleBar.Fullscreen leaves those
         unresolved and DefaultTimeBar crashes parsing "?2130968879" as int. -->
    <style name="Theme.SpatialFin.FCastInboundPlayer" parent="Theme.AppCompat.DayNight.NoActionBar">
        <item name="android:windowBackground">@android:color/black</item>
        <item name="android:windowFullscreen">true</item>
    </style>
</resources>
