<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <View
        android:id="@id/exo_controls_background"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#88000000" />

    <TextView
        android:id="@+id/fcast_inbound_control_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="top"
        android:ellipsize="end"
        android:maxLines="1"
        android:paddingStart="32dp"
        android:paddingTop="28dp"
        android:paddingEnd="32dp"
        android:textColor="@android:color/white"
        android:textSize="20sp"
        android:textStyle="bold"
        tools:text="Movie title" />

    <LinearLayout
        android:id="@id/exo_center_controls"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:gravity="center"
        android:layoutDirection="ltr"
        android:orientation="horizontal">

        <ImageButton
            android:id="@id/exo_rew"
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:background="@drawable/fcast_secondary_control_button"
            android:contentDescription="@string/player_controls_rewind"
            android:padding="18dp"
            android:scaleType="center"
            android:src="@drawable/ic_rewind"
            app:tint="@android:color/white" />

        <ImageButton
            android:id="@id/exo_play_pause"
            android:layout_width="88dp"
            android:layout_height="88dp"
            android:layout_marginStart="28dp"
            android:layout_marginEnd="28dp"
            android:background="@drawable/fcast_primary_play_button"
            android:contentDescription="@string/player_controls_play_pause"
            android:padding="24dp"
            android:scaleType="center"
            app:tint="@android:color/black" />

        <ImageButton
            android:id="@id/exo_ffwd"
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:background="@drawable/fcast_secondary_control_button"
            android:contentDescription="@string/player_controls_fast_forward"
            android:padding="18dp"
            android:scaleType="center"
            android:src="@drawable/ic_fast_forward"
            app:tint="@android:color/white" />
    </LinearLayout>

    <LinearLayout
        android:id="@id/exo_bottom_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:layoutDirection="ltr"
        android:orientation="vertical"
        android:paddingStart="32dp"
        android:paddingEnd="32dp"
        android:paddingBottom="28dp">

        <androidx.media3.ui.DefaultTimeBar
            android:id="@id/exo_progress"
            android:layout_width="match_parent"
            android:layout_height="32dp"
            android:contentDescription="@string/player_controls_progress"
            app:bar_height="4dp"
            app:buffered_color="#66FFFFFF"
            app:played_color="@color/logo_primary"
            app:scrubber_color="@android:color/white"
            app:unplayed_color="#33FFFFFF" />

        <LinearLayout
            android:id="@id/exo_time"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:importantForAccessibility="noHideDescendants"
            android:orientation="horizontal">

            <TextView
                android:id="@id/exo_position"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="sans"
                android:textColor="#E6FFFFFF"
                android:textSize="14sp"
                tools:text="00:14" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:paddingStart="8dp"
                android:paddingEnd="8dp"
                android:text="/"
                android:textColor="#99FFFFFF"
                android:textSize="14sp" />

            <TextView
                android:id="@id/exo_duration"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="sans"
                android:textColor="#B3FFFFFF"
                android:textSize="14sp"
                tools:text="42:20" />
        </LinearLayout>
    </LinearLayout>
</FrameLayout>
