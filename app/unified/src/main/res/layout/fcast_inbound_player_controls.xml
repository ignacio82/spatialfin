<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- Top Gradient Overlay -->
    <View
        android:layout_width="match_parent"
        android:layout_height="128dp"
        android:layout_gravity="top"
        android:background="@drawable/fcast_top_gradient" />

    <!-- Top Header Area -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="top"
        android:orientation="horizontal"
        android:paddingStart="48dp"
        android:paddingTop="32dp"
        android:paddingEnd="48dp"
        android:gravity="center_vertical">

        <ImageView
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:src="@drawable/ic_cast_connected"
            android:contentDescription="Cast Icon" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginStart="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="SpatialFin Receiver"
                android:textColor="#9ADBFF"
                android:textSize="28sp"
                android:textStyle="bold"
                android:fontFamily="sans-serif-medium" />

            <TextView
                android:id="@+id/fcast_inbound_header_subtitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Casting"
                android:textColor="#CCBDC8D0"
                android:textSize="16sp"
                android:fontFamily="sans-serif-medium" />
        </LinearLayout>
    </LinearLayout>

    <!-- Bottom Gradient Overlay -->
    <View
        android:layout_width="match_parent"
        android:layout_height="300dp"
        android:layout_gravity="bottom"
        android:background="@drawable/fcast_bottom_gradient" />

    <!-- Bottom Control Area -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:orientation="vertical"
        android:paddingStart="48dp"
        android:paddingEnd="48dp"
        android:paddingBottom="64dp">

        <!-- Metadata & Actions Row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="bottom"
            android:layout_marginBottom="32dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/fcast_inbound_control_title"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@android:color/white"
                    android:textSize="45sp"
                    android:textStyle="bold"
                    android:shadowColor="#80000000"
                    android:shadowDx="0"
                    android:shadowDy="4"
                    android:shadowRadius="8"
                    android:maxLines="1"
                    android:ellipsize="end"
                    tools:text="Void Walker" />

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="8dp">

                    <TextView
                        android:id="@+id/fcast_inbound_control_badge"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:background="@drawable/fcast_badge_background"
                        android:textColor="#BDC8D0"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:visibility="gone"
                        tools:visibility="visible"
                        tools:text="Audio Info" />
                </LinearLayout>
            </LinearLayout>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <ImageButton
                    android:id="@id/exo_subtitle"
                    android:layout_width="56dp"
                    android:layout_height="56dp"
                    android:layout_marginEnd="16dp"
                    android:background="@drawable/fcast_glass_button_background"
                    android:src="@drawable/ic_subtitles"
                    android:scaleType="center"
                    app:tint="@android:color/white"
                    android:contentDescription="Subtitles" />

                <ImageButton
                    android:id="@id/exo_audio_track"
                    android:layout_width="56dp"
                    android:layout_height="56dp"
                    android:layout_marginEnd="16dp"
                    android:background="@drawable/fcast_glass_button_background"
                    android:src="@drawable/ic_audiotrack"
                    android:scaleType="center"
                    app:tint="@android:color/white"
                    android:contentDescription="Audio Track" />

                <ImageButton
                    android:id="@id/exo_settings"
                    android:layout_width="56dp"
                    android:layout_height="56dp"
                    android:background="@drawable/fcast_glass_button_background"
                    android:src="@drawable/ic_settings"
                    android:scaleType="center"
                    app:tint="@android:color/white"
                    android:contentDescription="Settings" />
            </LinearLayout>
        </LinearLayout>

        <!-- Glass Panel Controls -->
        <LinearLayout
            android:id="@+id/fcast_glass_panel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/fcast_glass_panel_background"
            android:orientation="vertical"
            android:padding="24dp"
            android:elevation="16dp">

            <androidx.media3.ui.DefaultTimeBar
                android:id="@id/exo_progress"
                android:layout_width="match_parent"
                android:layout_height="32dp"
                android:contentDescription="@string/player_controls_progress"
                app:bar_height="4dp"
                app:buffered_color="#66FFFFFF"
                app:played_color="#9ADBFF"
                app:scrubber_color="#9ADBFF"
                app:unplayed_color="#33353A"
                android:layout_marginBottom="16dp" />

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical">

                <TextView
                    android:id="@id/exo_position"
                    android:layout_width="80dp"
                    android:layout_height="wrap_content"
                    android:layout_alignParentStart="true"
                    android:layout_centerVertical="true"
                    android:fontFamily="sans-serif-medium"
                    android:textColor="#BDC8D0"
                    android:textSize="14sp"
                    tools:text="34:12" />

                <LinearLayout
                    android:id="@id/exo_center_controls"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_centerInParent="true"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <ImageButton
                        android:id="@id/exo_prev"
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:layout_marginEnd="16dp"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:src="@drawable/ic_skip_previous"
                        android:scaleType="center"
                        app:tint="#BDC8D0"
                        android:contentDescription="Skip Previous" />

                    <ImageButton
                        android:id="@id/exo_rew"
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:layout_marginEnd="24dp"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:src="@drawable/ic_rewind"
                        android:scaleType="center"
                        app:tint="#BDC8D0"
                        android:contentDescription="@string/player_controls_rewind" />

                    <ImageButton
                        android:id="@id/exo_play_pause"
                        android:layout_width="64dp"
                        android:layout_height="64dp"
                        android:layout_marginEnd="24dp"
                        android:background="@drawable/fcast_primary_play_button"
                        android:contentDescription="@string/player_controls_play_pause"
                        android:scaleType="center"
                        app:tint="@android:color/black" />

                    <ImageButton
                        android:id="@id/exo_ffwd"
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:layout_marginEnd="16dp"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:src="@drawable/ic_fast_forward"
                        android:scaleType="center"
                        app:tint="#BDC8D0"
                        android:contentDescription="@string/player_controls_fast_forward" />

                    <ImageButton
                        android:id="@id/exo_next"
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:src="@drawable/ic_skip_next"
                        android:scaleType="center"
                        app:tint="#BDC8D0"
                        android:contentDescription="Skip Next" />

                </LinearLayout>

                <TextView
                    android:id="@id/exo_duration"
                    android:layout_width="80dp"
                    android:layout_height="wrap_content"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"
                    android:gravity="end"
                    android:fontFamily="sans-serif-medium"
                    android:textColor="#BDC8D0"
                    android:textSize="14sp"
                    tools:text="1:45:00" />
            </RelativeLayout>
        </LinearLayout>
    </LinearLayout>
</FrameLayout>
