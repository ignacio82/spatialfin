<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/black">

    <androidx.media3.ui.PlayerView
        android:id="@+id/fcast_inbound_player_view"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:keepScreenOn="true" />

    <!--
      Libass subtitle overlay. Stacked above the PlayerView so the rendered ASS bitmap covers
      the same projected video frame. Hit-tests disabled — PlayerView keeps its own click
      handling for the (default-hidden) controller. Visibility is driven from
      FCastInboundPlayerActivity's render loop: GONE whenever libass has no active cue or
      we're in split-A/V audio mode (no video to render subs over).
    -->
    <ImageView
        android:id="@+id/fcast_inbound_subtitle_overlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:contentDescription="Subtitles"
        android:scaleType="fitXY"
        android:clickable="false"
        android:focusable="false"
        android:visibility="gone" />

    <!--
      Visible only in split-A/V audio-only mode (this device plays audio while a paired
      video master drives the picture). PlayerView's video surface stays black anyway —
      this overlay is there so the user understands what they're looking at.
    -->
    <LinearLayout
        android:id="@+id/fcast_inbound_audio_only_overlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="32dp"
        android:visibility="gone">

        <TextView
            android:id="@+id/fcast_inbound_audio_only_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:text="Audio-only · Split A/V"
            android:textColor="#FFFFFFFF"
            android:textSize="24sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/fcast_inbound_audio_only_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:gravity="center"
            android:textColor="#CCFFFFFF"
            android:textSize="16sp" />

        <!--
          SpatialFin extension: source audio codec + transcoded flag, e.g.
          "Source · E-AC-3 · Direct play" or "Source · TrueHD → AAC · Transcoded".
          Populated from PlayMessage.metadata.custom.audio when present; GONE otherwise so
          non-SpatialFin senders don't get a stray empty line.
        -->
        <TextView
            android:id="@+id/fcast_inbound_audio_only_audio_info"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:gravity="center"
            android:textColor="#99B7C8FF"
            android:textSize="14sp"
            android:visibility="gone" />

        <TextView
            android:id="@+id/fcast_inbound_audio_only_hint"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:gravity="center"
            android:text="Video is rendered on the paired headset."
            android:textColor="#99FFFFFF"
            android:textSize="14sp" />

        <Button
            android:id="@+id/fcast_inbound_audio_only_stop"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="36dp"
            android:minWidth="200dp"
            android:minHeight="56dp"
            android:text="Stop"
            android:textSize="18sp"
            android:contentDescription="Stop split-A/V playback" />
    </LinearLayout>
</FrameLayout>
