<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical">

    <androidx.media3.ui.DefaultTimeBar
        android:id="@id/exo_progress"
        android:layout_width="match_parent"
        android:layout_height="32dp"
        android:contentDescription="@string/player_controls_progress"
        app:bar_height="4dp"
        app:buffered_color="#66FFFFFF"
        app:played_color="#9ADBFF"
        app:scrubber_color="#9ADBFF"
        app:unplayed_color="#33353A"
        android:layout_marginBottom="16dp" />

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical">

        <TextView
            android:id="@id/exo_position"
            android:layout_width="80dp"
            android:layout_height="wrap_content"
            android:layout_alignParentStart="true"
            android:layout_centerVertical="true"
            android:fontFamily="sans-serif-medium"
            android:textColor="#BDC8D0"
            android:textSize="14sp"
            tools:text="34:12" />

        <LinearLayout
            android:id="@id/exo_center_controls"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <ImageButton
                android:id="@id/exo_prev"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_marginEnd="16dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@drawable/ic_skip_previous"
                android:scaleType="center"
                app:tint="#BDC8D0"
                android:contentDescription="Skip Previous" />

            <ImageButton
                android:id="@id/exo_rew"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_marginEnd="24dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@drawable/ic_rewind"
                android:scaleType="center"
                app:tint="#BDC8D0"
                android:contentDescription="@string/player_controls_rewind" />

            <FrameLayout
                android:layout_width="64dp"
                android:layout_height="64dp"
                android:layout_marginEnd="24dp">
                <ImageButton
                    android:id="@+id/fcast_btn_play"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@drawable/fcast_primary_play_button"
                    android:src="@drawable/fcast_ic_play_filled"
                    android:contentDescription="Play"
                    android:scaleType="center"
                    app:tint="@android:color/black" />
                <ImageButton
                    android:id="@+id/fcast_btn_pause"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@drawable/fcast_primary_play_button"
                    android:src="@drawable/fcast_ic_pause_filled"
                    android:contentDescription="Pause"
                    android:scaleType="center"
                    app:tint="@android:color/black" />
            </FrameLayout>

            <ImageButton
                android:id="@id/exo_ffwd"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_marginEnd="16dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@drawable/ic_fast_forward"
                android:scaleType="center"
                app:tint="#BDC8D0"
                android:contentDescription="@string/player_controls_fast_forward" />

            <ImageButton
                android:id="@id/exo_next"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@drawable/ic_skip_next"
                android:scaleType="center"
                app:tint="#BDC8D0"
                android:contentDescription="Skip Next" />

        </LinearLayout>

        <TextView
            android:id="@id/exo_duration"
            android:layout_width="80dp"
            android:layout_height="wrap_content"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:gravity="end"
            android:fontFamily="sans-serif-medium"
            android:textColor="#BDC8D0"
            android:textSize="14sp"
            tools:text="1:45:00" />
    </RelativeLayout>
</LinearLayout>
