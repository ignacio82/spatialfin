prefix=/home/ignacio/SpatialFin/build_native_work/prefix_x86_64
includedir=${prefix}/include
libdir=${prefix}/lib

Name: libass
Description: libass is an SSA/ASS subtitles rendering library
Version: 0.17.3
Requires: freetype2 >=  9.17.3, fribidi >=  0.19.1, harfbuzz >=  1.2.3
Libs: -L${libdir} -lass -lm
Cflags: -I${includedir}
